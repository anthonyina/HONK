{
  "name": "product-intake",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.14.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development ts-node --project tsconfig.server.json --transpile-only server/index.ts | pino-pretty",
    "predev": "npm run generate-multipart-paths",
    "prebuild": "npm run generate-multipart-paths",
    "build": "next build && npm run build:server",
    "start": "next start",
    "build:server": "tsc --project tsconfig.server.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate-multipart-paths": "node scripts/generate-valid-multipart-path-prefixes.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.8",
    "@mui/material-nextjs": "^7.3.8",
    "@mui/x-date-pickers": "^8.27.2",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/user-event": "^14.6.1",
    "dayjs": "^1.11.20",
    "next": "16.1.6",
    "openai": "^6.33.0",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
